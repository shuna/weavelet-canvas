From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: weavelet-canvas <noreply@weavelet.local>
Subject: [PATCH 1/1] cmake: add onebit kernel sources to wllama build

Adds the independent onebit matmul kernel and model-builder helper
to the wllama WASM binary. These are new source files placed in
cpp/onebit/ — no existing files are modified.

The onebit kernel implements:
  out = diag(a) * unpack(sign) * diag(b) * x

using ggml_map_custom3_inplace (no ggml.h enum changes required).

---
 CMakeLists.txt | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 1234567..abcdefg 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -9,9 +9,19 @@ set(WLLAMA_SRC cpp/wllama.cpp
     cpp/actions.hpp
     cpp/glue.hpp
     cpp/helpers/wlog.cpp
     cpp/helpers/wcommon.cpp
     cpp/helpers/wsampling.cpp
     llama.cpp/include/llama.h)
+
+# Onebit quantization kernel (independent from ggml core)
+set(ONEBIT_SRC
+    cpp/onebit/onebit-mul-mat.c
+    cpp/onebit/onebit-model-builder.c)
+
 include_directories(${CMAKE_CURRENT_SOURCE_DIR}/cpp)
 include_directories(${CMAKE_CURRENT_SOURCE_DIR}/cpp/helpers)
 include_directories(${CMAKE_CURRENT_SOURCE_DIR}/llama.cpp/include)
+include_directories(${CMAKE_CURRENT_SOURCE_DIR}/cpp/onebit)
+include_directories(${CMAKE_CURRENT_SOURCE_DIR}/llama.cpp/ggml/include)

-add_executable(wllama ${WLLAMA_SRC})
+add_executable(wllama ${WLLAMA_SRC} ${ONEBIT_SRC})
 target_link_libraries(wllama PRIVATE ggml llama ${CMAKE_THREAD_LIBS_INIT})
